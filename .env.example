# Google Sheets Integration (Backend)
# 1. Create a Service Account in Google Cloud Console
# 2. Enable Google Sheets API
# 3. Download JSON key and set these variables
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Drive Sync (Frontend / Admin Dashboard)
# 1. Create an OAuth 2.0 Client ID (Web Application) in Google Cloud Console
# 2. Add your App URLs to Authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Admin Dashboard Credentials
# Change these to secure your admin portal
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin123

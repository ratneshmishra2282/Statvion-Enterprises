{
  "entities": {
    "AdminUser": {
      "title": "AdminUser",
      "description": "An administrator user who can access the CMS.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the admin."
        },
        "role": {
          "type": "string",
          "enum": ["admin"],
          "description": "The role of the user."
        }
      },
      "required": ["email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by the company.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "category": { "type": "string", "enum": ["it", "consultancy", "development"] }
      },
      "required": ["title", "description", "icon", "category"]
    },
    "ContactResponse": {
      "title": "ContactResponse",
      "description": "A message submitted via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["name", "email", "subject", "message", "timestamp"]
    },
    "GlobalState": {
      "title": "GlobalState",
      "description": "Global application state including content, images, and theme.",
      "type": "object",
      "properties": {
        "content": {
          "type": "object",
          "properties": {
            "heroTitle": { "type": "string" },
            "heroSubtitle": { "type": "string" },
            "aboutText": { "type": "string" },
            "vision": { "type": "string" },
            "mission": { "type": "string" }
          }
        },
        "images": {
          "type": "object",
          "properties": {
            "homeStrategy": { "type": "string" },
            "aboutHero": { "type": "string" },
            "contactMap": { "type": "string" },
            "logoUrl": { "type": "string" },
            "faviconUrl": { "type": "string" }
          }
        },
        "theme": {
          "type": "object",
          "properties": {
            "fontFamily": { "type": "string" },
            "fontSize": { "type": "string" }
          }
        }
      }
    }
  },
  "firestore": {
    "/admins/{userId}": {
      "schema": { "$ref": "#/entities/AdminUser" },
      "description": "Stores admin users."
    },
    "/services/{serviceId}": {
      "schema": { "$ref": "#/entities/Service" },
      "description": "Stores services offered."
    },
    "/contactResponses/{responseId}": {
      "schema": { "$ref": "#/entities/ContactResponse" },
      "description": "Stores contact form submissions."
    },
    "/appState/global": {
      "schema": { "$ref": "#/entities/GlobalState" },
      "description": "Stores global CMS configuration."
    }
  }
}
